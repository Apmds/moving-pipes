[node name="AnimationPlayer" type="AnimationPlayer" parent="."]
anims/RESET = SubResource( 3 )
anims/start_game = SubResource( 4 )

[node name="Add_pipe_sound" type="AudioStreamPlayer2D" parent="."]
stream = ExtResource( 14 )
bus = "sound_effects"

[node name="Button_sound" type="AudioStreamPlayer2D" parent="."]
stream = ExtResource( 9 )
bus = "sound_effects"

[node name="Pipe_timer" type="Timer" parent="."]
wait_time = 2.5

[node name="Power_up_timer" type="Timer" parent="."]
wait_time = 5.0
one_shot = true

[connection signal="timeout" from="BG/BG_element_timer" to="." method="_on_BG_element_timer_timeout"]
[connection signal="pressed" from="HUD/Main_menu_button" to="." method="_on_Main_menu_button_pressed"]
[connection signal="tween_completed" from="Tween" to="." method="_on_Tween_tween_completed"]
[connection signal="timeout" from="Pipe_timer" to="." method="_on_Pipe_timer_timeout"]
[connection signal="timeout" from="Power_up_timer" to="." method="_on_Power_up_timer_timeout"]
